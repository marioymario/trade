
# =========================================================
# MJÖLNIR runtime config template
# Purpose:
# - shared schema/reference truth for local and old-box .env files
# - keep structure, comments, and key set aligned across environments
# - allow only intentional value differences between local and old-box
#
# Notes:
# - this file is tracked in git
# - real .env files are runtime/operator state and are NOT tracked
# - old-box values should reflect live mission truth
# - local values may be safer/lighter, but should keep the same shape
# =========================================================

# -------------------------
# Market / storage identity
# -------------------------
DATA_TAG=paper_oldbox_live
SYMBOL=BTC/USD
TIMEFRAME=5m
CCXT_EXCHANGE=coinbase

# -------------------------
# Broker mode
# -------------------------
DRY_RUN=1
BROKER=paper

# -------------------------
# Loop / data requirements
# -------------------------
MIN_BARS=200
LOOP_SLEEP_SECONDS=60
COOLDOWN_BARS=3

# -------------------------
# Paper cost model
# -------------------------
FEE_BPS=8
SLIPPAGE_BPS=5

# -------------------------
# Strategy sizing
# -------------------------
MAX_ORDER_SIZE=0.01

# -------------------------
# Operator safety files
# -------------------------
KILL_SWITCH_FILE=/home/kk7wus/trade_flags/STOP
HALT_ORDERS_FILE=/home/kk7wus/trade_flags/HALT
ARM_FILE=/home/kk7wus/trade_flags/ARM

# -------------------------
# Submit-boundary guardrails
# -------------------------
MAX_ORDER_USD=1000
MAX_POSITION_USD=1000
MAX_DAILY_LOSS_USD=100
MAX_TRADES_PER_DAY=0

# -------------------------
# Timezone for daily limits
# -------------------------
TZ_LOCAL=America/Los_Angeles

# -------------------------
# Deprecated / non-authoritative
# -------------------------
ARMED=1

# -------------------------
# Optional / compatibility
# -------------------------
# Keep only if some local workflows still use it.
PAPERBROKER_USE_ALPACA=0

# -------------------------
# Proof / test hooks
# Default: OFF
# -------------------------
TEST_HOOKS_ENABLED=0
FORCE_ENTRY_SIGNAL_ONCE=0
FORCE_EXIT_SIGNAL_ONCE=0
FORCE_FEATURES_INVALID_N=0
FORCE_COOLDOWN_BLOCK_ONCE=0
FORCE_COOLDOWN_BARS=0
FORCE_CADENCE_FAIL_N=0
BYPASS_FEATURE_VALIDATION=0

# -------------------------
# Optional strategy/debug keys
# -------------------------
# SYMBOL_ALLOWLIST=BTC/USD
# FORCE_SIDE=LONG
# FORCE_SIDE=SHORT
